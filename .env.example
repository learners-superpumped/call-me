# CallMe MCP Server Configuration
# Set these environment variables before using the CallMe plugin

# ===================
# Phone Provider (ClawOps)
# ===================

# Get these from the ClawOps web dashboard (Settings > API Keys)
CALLME_PHONE_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx    # Account ID
CALLME_PHONE_API_KEY=sk_your_api_key           # API Key for API calls
CALLME_PHONE_SIGNING_KEY=your_signing_key      # Webhook Signing Key

# The phone number to call FROM (provisioned via ClawOps dashboard)
CALLME_PHONE_NUMBER=+821012345678

# ===================
# Your Phone Number
# ===================
# The phone number to call YOU at (SIP extension or E.164)
CALLME_USER_PHONE_NUMBER=softphone

# ===================
# Speech Services
# ===================
# OpenAI API key (required for speech-to-text and text-to-speech)
CALLME_OPENAI_API_KEY=sk-xxx

# ===================
# ngrok
# ===================
# Get a free auth token at https://dashboard.ngrok.com/get-started/your-authtoken
CALLME_NGROK_AUTHTOKEN=your_ngrok_authtoken

# Optional: Use a custom ngrok domain (paid feature)
# CALLME_NGROK_DOMAIN=your-domain.ngrok.io

# ===================
# Optional
# ===================
# ClawOps API base URL (default: https://api.claw-ops.com)
# CALLME_CLAWOPS_BASE_URL=https://api.claw-ops.com

# Local HTTP port for webhooks (default: 3333)
# CALLME_PORT=3333

# Daemon control API port (default: 3334)
# CALLME_CONTROL_PORT=3334
